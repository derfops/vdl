# Copie para .env e preencha com valores reais. O .env é gitignored.
# Credenciais OpenVPN (CyberGhost) lidas por docker-compose.yml.
OPENVPN_USER=seu_usuario_cyberghost
OPENVPN_PASSWORD=sua_senha_cyberghost
OPENAI_API_KEY=
VDL_TOKEN=
# Raiz do storage montada em /data/storage (Studio, workers novpn/windscribe/cyberghost).
STORAGE_DIR=./data/storage
