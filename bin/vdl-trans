#!/usr/bin/env bash
#
# vdl-trans — atalho para transcrição LOCAL (sem Docker) no macOS/Linux.
#
# Usa o venv local do repositório (.venv-vdl) para transcrever, com o destino
# dos artefatos = a própria pasta do alvo (a pasta do arquivo, ou a pasta em si
# quando o alvo é um diretório).
#
# Engines de transcrição:
#   mlx  — mlx-whisper na GPU Apple (Metal): ~9x mais rápido. Só Apple Silicon.
#   cpu  — faster-whisper em CPU/int8 (mesmo do servidor; roda em qualquer lugar).
#   auto — (padrão) usa mlx no Apple Silicon se instalado; senão, cai no cpu.
#
# Uso:
#   vdl-trans <arquivo|pasta> [--model tiny|base|small|medium|large] [--engine auto|mlx|cpu] [flags extras do vdl.py]
#
# Exemplos:
#   vdl-trans "video.mp4"                      # 1 arquivo (auto: GPU no Mac)
#   vdl-trans ~/Videos                         # pasta inteira (recursivo)
#   vdl-trans aula.mp4 --model small           # modelo mais rápido
#   vdl-trans aula.mp4 --engine cpu            # força faster-whisper (CPU)
#   VDL_MODEL=large VDL_ENGINE=mlx vdl-trans aula.mp4   # via variáveis de ambiente
#   vdl-trans aula.mp4 --context               # repassa --context (usa engine cpu)
#
# Modelo padrão: medium. Engine padrão: auto. Sobrescrevíveis por --model/--engine
# (logo após o alvo) ou pelas envs VDL_MODEL / VDL_ENGINE. Flags extras que
# dependem do vdl.py (ex.: --context) forçam a engine cpu automaticamente.
set -euo pipefail

# --- Resolve o caminho real do script, seguindo symlinks ---
# (este script normalmente é instalado como symlink em ~/.local/bin ou
#  /usr/local/bin, então $0 aponta para o link, não para o arquivo real).
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
REPO="$(cd "$SCRIPT_DIR/.." >/dev/null 2>&1 && pwd)"

PY="$REPO/.venv-vdl/bin/python"
VDL="$REPO/vdl.py"
MLX="$REPO/_transcription_mlx.py"
MODEL="${VDL_MODEL:-medium}"
ENGINE="${VDL_ENGINE:-auto}"

usage() {
  # Imprime o bloco de comentário do cabeçalho (a partir da linha 3), parando
  # na primeira linha que não for comentário. Robusto a edições no cabeçalho.
  awk 'NR>=3 && /^#/ {sub(/^# ?/,""); print; next} NR>=3 {exit}' "$SOURCE"
}

# --- Validação de pré-requisitos ---
if [ ! -x "$PY" ]; then
  echo "vdl-trans: venv não encontrado em '$PY'." >&2
  echo "           Crie-o uma vez com:" >&2
  echo "             cd \"$REPO\" && python3 -m venv .venv-vdl && ./.venv-vdl/bin/pip install -r requirements.txt" >&2
  echo "           (veja docs/TRANSCRICAO-LOCAL.md)" >&2
  exit 1
fi
if [ ! -f "$VDL" ]; then
  echo "vdl-trans: não encontrei vdl.py em '$VDL'." >&2
  exit 1
fi

# --- Argumentos ---
if [ "$#" -eq 0 ] || [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
fi

TARGET="$1"; shift

# Opções do wrapper (--model / --engine), em qualquer ordem, logo após o alvo.
while [ "${1:-}" = "--model" ] || [ "${1:-}" = "--engine" ]; do
  case "$1" in
    --model)
      [ "$#" -ge 2 ] || { echo "vdl-trans: --model requer um valor (tiny|base|small|medium|large)." >&2; exit 1; }
      MODEL="$2"; shift 2;;
    --engine)
      [ "$#" -ge 2 ] || { echo "vdl-trans: --engine requer um valor (auto|mlx|cpu)." >&2; exit 1; }
      ENGINE="$2"; shift 2;;
  esac
done
# "$@" a partir daqui = flags extras repassadas ao vdl.py (ex.: --context).

if [ ! -e "$TARGET" ]; then
  echo "vdl-trans: alvo não encontrado: $TARGET" >&2
  exit 1
fi

# --- Caminho absoluto + destino = a própria pasta do alvo ---
if [ -d "$TARGET" ]; then
  TARGET="$(cd "$TARGET" >/dev/null 2>&1 && pwd)"
  DEST="$TARGET"
else
  TARGET="$(cd "$(dirname "$TARGET")" >/dev/null 2>&1 && pwd)/$(basename "$TARGET")"
  DEST="$(dirname "$TARGET")"
fi

# --- Resolução da engine ---
# Flags extras (ex.: --context, -u) usam o fluxo do vdl.py → forçam cpu.
if [ "$#" -gt 0 ]; then
  if [ "$ENGINE" = "mlx" ]; then
    echo "vdl-trans: flags extras ($*) não são suportadas pela engine mlx; usando cpu." >&2
  fi
  ENGINE="cpu"
fi

mlx_ok() {
  [ "$(uname -s)" = "Darwin" ] && [ "$(uname -m)" = "arm64" ] \
    && "$PY" -c 'import importlib.util,sys; sys.exit(0 if importlib.util.find_spec("mlx_whisper") else 1)' >/dev/null 2>&1
}

case "$ENGINE" in
  auto)
    if mlx_ok; then ENGINE="mlx"; else ENGINE="cpu"; fi
    ;;
  mlx)
    if ! mlx_ok; then
      echo "vdl-trans: engine mlx indisponível (requer Apple Silicon + mlx-whisper); usando cpu." >&2
      ENGINE="cpu"
    fi
    ;;
  cpu) ;;
  *)
    echo "vdl-trans: --engine inválido: '$ENGINE' (use auto|mlx|cpu)." >&2
    exit 1
    ;;
esac

# Roda a partir do repo para que o diretório logs/ do vdl.py caia no repo
# (ignorado pelo git), e não na pasta de onde o usuário chamou o comando.
cd "$REPO"

if [ "$ENGINE" = "mlx" ]; then
  exec "$PY" "$MLX" "$TARGET" -d "$DEST" --whisper-model "$MODEL"
else
  exec "$PY" "$VDL" "$TARGET" --local --transcribe -d "$DEST" --whisper-model "$MODEL" "$@"
fi
